# Supabase (Dashboard > Project Settings > API)
# Python client (supabase-py) şu an sadece Legacy JWT key destekliyor. API Keys sayfasında
# "Legacy API Keys" sekmesinden service_role (eyJ... ile başlayan uzun key) kopyalayın.
# sb_secret_... formatı bu client ile "Invalid API key" verir.
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxx
