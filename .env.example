# =============================================================================
# Yerel Supabase (önerilen: Docker + Supabase CLI)
# =============================================================================
# 1) CLI: https://supabase.com/docs/guides/cli
#    macOS: brew install supabase/tap/supabase
# 2) Repo kökünde (mustafa-proje/):  supabase init
# 3) Docker açıkken:                supabase start
# 4) Anahtarları gör:                supabase status
#    - API URL genelde: http://127.0.0.1:54321
#    - "service_role" / JWT secret (genelde eyJ... ile başlar) → SUPABASE_SERVICE_KEY
# 5) Şema: Tarayıcıda Studio       http://127.0.0.1:54323
#    SQL Editor’da backend/supabase_schema.sql (ve gerekirse supabase_migrate_all.sql) çalıştırın.
#
# Yerel örnek:
# SUPABASE_URL=http://127.0.0.1:54321
# SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9....   # supabase status çıktısı

# =============================================================================
# Bulut (supabase.com projesi)
# =============================================================================
# Dashboard → Project Settings → API
# SUPABASE_URL=https://xxxxx.supabase.co
# SUPABASE_SERVICE_KEY=sb_secret_...   veya dashboard’daki service_role secret
#
# Not: Backend tarayıcı anahtarı (publishable / sb_publishable_) kullanmamalı;
# supabase_client publishable key ile istemci oluşturmaz.

# Opsiyonel; backend önce SUPABASE_SERVICE_KEY okur.
# SUPABASE_KEY=

PORT=8000
